    <PackageVersion Include="SimpleInfoName" Version="3.2.0" />
    <PackageVersion Include="SponsorCheck" Version="0.10.0" GitHubSponsorsAccount="VerifyTests" />
    <!-- CVE -->
    <PackageVersion Include="System.Text.Json" Version="10.0.9" />
