    <PackageVersion Include="NUnit3TestAdapter" Version="6.2.0" />
    <PackageVersion Include="ProjectDefaults" Version="1.0.174" />
    <PackageVersion Include="Syncfusion.DocIO.Net.Core" Version="33.2.12" />
    <PackageVersion Include="Syncfusion.DocIORenderer.Net.Core" Version="33.2.12" />
    <PackageVersion Include="Syncfusion.EJ2.PdfViewer.AspNet.Core" Version="33.2.12" />
    <PackageVersion Include="Syncfusion.Pdf.Net.Core" Version="33.2.13" />
    <PackageVersion Include="Syncfusion.Presentation.Net.Core" Version="33.2.13" />
    <PackageVersion Include="Syncfusion.PresentationRenderer.Net.Core" Version="33.2.13" />
    <PackageVersion Include="Syncfusion.XlsIO.Net.Core" Version="33.2.12" />
    <PackageVersion Include="Syncfusion.XlsIORenderer.Net.Core" Version="33.2.12" />
    <PackageVersion Include="Verify" Version="31.19.1" />
    <PackageVersion Include="Verify.DiffPlex" Version="3.2.0" />
    <PackageVersion Include="Verify.NUnit" Version="31.19.1" />
    <PackageVersion Include="Microsoft.Sbom.Targets" Version="4.1.5" />
    <PackageVersion Include="Microsoft.Extensions.Caching.Memory" Version="10.0.9" />
    <PackageVersion Include="Argon" Version="0.34.0" />
